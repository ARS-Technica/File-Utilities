def output_playlist(file_path, playlist):
    """
    Outputs the playlist to the console.
    """
    print(f"There are {len(playlist)} songs in this playlist.")
    print(f"Tracks found in {file_path}:\n")

    for song in playlist:
        # print(f"Title: {song['title']}, Path: {song['path']}")

        print(f"Title: {song['title']}")
        print(f"Path/URL: {song['clean_path']}\n")    

    return None


def main():
    # Prompt the user for the file path
    user_input = input("Enter the full path to your playlist file: ")

    # Clean up accidental spaces or quotes around the path
    file_path = user_input.strip().strip("'\"")

    # Define the extensions we are looking for
    extensions = ('.xspf', '.m3u', '.m3u8')

    # Check if the file actually exists before running
    if os.path.exists(file_path):
        if file_path.suffix.lower() in extensions:
            # Route to the correct parsing function based on extension
            if file_path.suffix.lower() == '.xspf':
                parse_xspf(file_path)
            else:
                parse_m3u(file_path)

        # playlist = parse_xspf_playlist(file_path)
        # print(f"Successfully processed {len(playlist)} songs.")
    else:
        print(f"\nError: Could not find a playlist file (.xspf, .m3u, .m3u8) at '{file_path}'. Please check the path and try again.")


if __name__ == "__main__":
    main()



