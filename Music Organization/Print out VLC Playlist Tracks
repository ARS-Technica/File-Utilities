Description: Use Python to read a vlc playlist file

An XSPF (XML Shareable Playlist Format) file is a 
type of XML file. You can read it using Python's 
built-in xml.etree.ElementTree library to find all the 
track locations.
"""

from turtle import title

import os # For prompting user for a file path
import sys # Reconfigures filenames to UTF-8 to avoid UnicodeDecodeError when printing paths
from urllib.parse import unquote  # For decoding URL-encoded paths
import xml.etree.ElementTree as ET


# Force stdout to use UTF-8 and safely replace characters your terminal can't display
sys.stdout.reconfigure(encoding='utf-8', errors='replace')


def parse_xspf_playlist(file_path):
    """
    Parses XML-based VLC playlists.
    """
    songs = []

    # Parse the XML file
    tree = ET.parse(file_path)
    root = tree.getroot()
    
    # Define the XSPF namespace to find elements correctly
    namespace = {'ns': 'http://xspf.org/ns/0/'}

    print(f"--- Tracks found in {file_path} ---")

    # Find all <track> tags inside <trackList>
    for track in root.findall('.//ns:track', namespace):
        title_element = track.find('ns:title', namespace)
        location_element = track.find('ns:location', namespace) 

        # Extract text if the elements exist
        title = title_element.text if title_element is not None else "Unknown Title"
        location = location_element.text if location_element is not None else "Unknown Location"

        # VLC encodes local file paths as URLs (e.g., file:///C:/Music/song.mp3)
        # Replace troublesome zero-width spaces manually
        clean_path = unquote(location).replace('\u200b', '')

        # ...Alternatively, safely encode to printable ascii/utf-8 string
        #safe_title = title.encode('ascii', errors='ignore').decode('ascii')

        print(f"Title: {title}")
        print(f"Path/URL: {clean_path}\n")    

        # Collect into dictionary so the returned list has data
        songs.append({"title": title, "path": clean_path})            

    return songs


